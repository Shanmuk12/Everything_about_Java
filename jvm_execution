let activeComp = null;

function show(id){
  const d = DATA[id];
  if(!d) return;
  if(activeComp) activeComp.classList.remove('active');
  const el = document.querySelector(`[onclick="show('${id}')"]`);
  if(el){ el.classList.add('active'); activeComp = el; }

  document.getElementById('panel-empty').style.display = 'none';
  const content = document.getElementById('panel-content');
  content.style.display = 'block';

  document.getElementById('pbadge').textContent = d.badge;
  document.getElementById('pbadge').style.background = d.bc + '22';
  document.getElementById('pbadge').style.color = d.bc;
  document.getElementById('ptitle').textContent = d.title;
  document.getElementById('pdef').textContent = d.def;

  let html = '';
  if(d.points && d.points.length){
    html += '<div class="sh">Key Facts</div>';
    d.points.forEach(p => { html += `<div class="kp">${p}</div>`; });
  }
  if(d.code){
    html += `<div class="sh" style="margin-top:12px">Code / Flags</div><div class="code">${d.code}</div>`;
  }
  if(d.tip){
    html += `<div class="tip"><div class="tiph">⚡ FAANG Interview Tip</div><div class="tipt">${d.tip}</div></div>`;
  }
  document.getElementById('pbody').innerHTML = html;
}
