'escape-analysis':{
  badge:'Stage 13 · Execution',bc:'#f472b6',
  title:'Escape Analysis & Scalar Replacement',
  def:'A C2 JIT compiler optimization. The JIT analyzes if a newly created object "escapes" the method it was created in (e.g., returned, passed to another thread, assigned to a global field). If it does NOT escape, the JVM can completely optimize away the heap allocation.',
  points:[
